# Service Studio by Ruslan — environment variables
# Copy this file to .env.local and fill in real values. Never commit real secrets.

# --- Contact form email delivery (Resend — https://resend.com) ---

# Resend API key. Server-side only — never exposed to the browser.
# Create one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered (your inbox).
CONTACT_TO_EMAIL=you@example.com

# Verified sender in Resend. Must use a domain/sender you've verified.
# Format: "Display Name <address@yourdomain.com>"
CONTACT_FROM_EMAIL=Service Studio <noreply@yourdomain.com>

# --- Site ---

# Public site URL, used for canonical/OpenGraph metadata, sitemap, and robots.
# No trailing slash.
# Local: http://localhost:3000  |  Production: https://servicestudiobyruslan.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
